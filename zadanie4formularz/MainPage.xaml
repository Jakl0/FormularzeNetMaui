<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zadanie4formularz.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">


            <Entry Text="" x:Name="nameEntry" MaxLength="100" Placeholder="Imie" />
            <Entry Text="" x:Name="mailEntry"  Keyboard="Email" Placeholder="Email"/>

            <Picker SelectedIndexChanged="tematchanged" x:Name="tematPicker" Title="Temat"/>


            <Editor x:Name="messageEdit" Placeholder="Treść wiadomości..."/>

            <Picker SelectedIndexChanged="priorytetchanged" x:Name="priorPicker" Title="Priorytet"/>
            <HorizontalStackLayout>
                <CheckBox x:Name="copyCheckbox" />
                <Label Text="Wyślij mi kopię wiadomości na email" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Button Text="Wyślij" Clicked="OnMessageClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
